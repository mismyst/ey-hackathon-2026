# Application
SHELDRA_ENV=development
SHELDRA_LOG_LEVEL=INFO
SHELDRA_CORS_ORIGINS=http://localhost:3000
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Infrastructure credentials (replace before deployment)
